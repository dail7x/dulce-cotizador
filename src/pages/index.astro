<!-- Lógica Interactiva (Vanilla JS para Filtros + Cotizador) -->
<script define:vars={{ products, WHATSAPP_PHONE }}>
  // variables globales inyectadas desde Astro: products, WHATSAPP_PHONE
  let selectedProduct = null;
  let quoteSize = null;
  let quoteFillings = [];
  let quoteDesign = null;

  // --- SINCRONIZACIÓN CON GOOGLE SHEETS (OPCIONAL) ---
  // Para activar, colocá la ID de tu planilla de Google Sheets.
  // Ejemplo: const GOOGLE_SHEET_ID = "123456789X-Y_Z...";
  // Dejalo vacío "" para usar solo la base local gestionada por Keystatic.
  const GOOGLE_SHEET_ID = ""; 

  if (GOOGLE_SHEET_ID) {
    const csvUrl = `https://docs.google.com/spreadsheets/d/${GOOGLE_SHEET_ID}/export?format=csv`;
    
    fetch(csvUrl)
      .then(res => {
        if (!res.ok) throw new Error("Error de conexión");
        return res.text();
      })
      .then(csvText => {
        const rows = parseCSV(csvText);
        rows.forEach(row => {
          const productId = row.id;
          if (!productId) return;
          
          // Actualizar la lista en memoria (para cálculos y reservas)
          const product = products.find(p => p.id === productId);
          if (product) {
            if (row.precio !== undefined && row.precio !== "") {
              product.precio = Number(row.precio);
            }
            if (row.diasAnticipacion !== undefined && row.diasAnticipacion !== "") {
              product.diasAnticipacion = Number(row.diasAnticipacion);
            }
            if (row.aptoCelicos !== undefined && row.aptoCelicos !== "") {
              product.aptoCelicos = row.aptoCelicos.toLowerCase() === 'true';
            }
            if (row.descripcion) {
              product.descripcion = row.descripcion;
            }
            
            // Actualizar la interfaz (DOM)
            const card = document.querySelector(`.product-card[data-id="${productId}"]`);
            if (card) {
              // Actualizar precio
              const priceVal = card.querySelector('.price-value');
              if (priceVal && product.tipoPrecio !== 'cotizar') {
                priceVal.textContent = `$${product.precio.toLocaleString('es-AR')}`;
              }
              
              // Actualizar descripción
              const descVal = card.querySelector('.product-card-desc');
              if (descVal && row.descripcion) {
                descVal.textContent = row.descripcion;
              }
              
              // Actualizar anticipación
              const advanceVal = card.querySelector('.product-advance');
              if (advanceVal) {
                advanceVal.textContent = `⏱️ Min. ${product.diasAnticipacion} ${product.diasAnticipacion === 1 ? 'día' : 'días'}`;
              }
            }
          }
        });
        console.log("¡Catálogo sincronizado exitosamente con Google Sheets!");
      })
      .catch(err => {
        console.warn("Sincronización de Google Sheets fallida. Usando datos de Keystatic.", err);
      });
  }

  // Analizador simple de CSV
  function parseCSV(text) {
    const lines = text.split('\n');
    if (lines.length === 0) return [];
    
    const headers = lines[0].split(',').map(h => h.replace(/^["\r]+|["\r]+$/g, '').trim());
    const result = [];
    
    for (let i = 1; i < lines.length; i++) {
      const line = lines[i].trim();
      if (!line) continue;
      
      const row = [];
      let currentField = '';
      let inQuotes = false;
      
      for (let j = 0; j < line.length; j++) {
        const char = line[j];
        if (char === '"') {
          inQuotes = !inQuotes;
        } else if (char === ',' && !inQuotes) {
          row.push(currentField.replace(/^["\r]+|["\r]+$/g, '').trim());
          currentField = '';
        } else {
          currentField += char;
        }
      }
      row.push(currentField.replace(/^["\r]+|["\r]+$/g, '').trim());
      
      const item = {};
      headers.forEach((header, index) => {
        if (row[index] !== undefined) {
          item[header] = row[index];
        }
      });
      result.push(item);
    }
    return result;
  }

  // --- FILTROS DEL CATÁLOGO ---
  const filterTabs = document.querySelectorAll('.filter-tab');
  const productCards = document.querySelectorAll('.product-card');

  filterTabs.forEach(tab => {
    tab.addEventListener('click', () => {
      // Activar tab visualmente
      filterTabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');

      const filterValue = tab.getAttribute('data-filter');

      productCards.forEach(card => {
        const category = card.getAttribute('data-category');
        const isCeliac = card.getAttribute('data-celiac') === 'true';

        if (filterValue === 'all') {
          card.style.display = 'flex';
        } else if (filterValue === 'celiac') {
          card.style.display = isCeliac ? 'flex' : 'none';
        } else {
          card.style.display = category === filterValue ? 'flex' : 'none';
        }
      });
    });
  });

  // --- CONTROL DE MODALES ---
  const modalCotizador = document.getElementById('modal-cotizador');
  const modalPedidoFijo = document.getElementById('modal-pedido-fijo');
  const modalQuote = document.getElementById('modal-quote');

  function openModal(modal) {
    modal.classList.add('open');
    document.body.style.overflow = 'hidden'; // Evita scroll de fondo
  }

  function closeModal(modal) {
    modal.classList.remove('open');
    document.body.style.overflow = '';
  }

  // Cerrar al clickear fuera de la tarjeta modal
  [modalCotizador, modalPedidoFijo, modalQuote].forEach(modal => {
    modal.addEventListener('click', (e) => {
      if (e.target === modal) {
        closeModal(modal);
      }
    });
  });

  // Botones de cerrar del modal
  document.getElementById('btn-close-cotizador').addEventListener('click', () => closeModal(modalCotizador));
  document.getElementById('btn-close-pedido-fijo').addEventListener('click', () => closeModal(modalPedidoFijo));
  document.getElementById('btn-close-quote').addEventListener('click', () => closeModal(modalQuote));

  // Configurar las fechas mínimas requeridas según anticipación
  function setMinDate(dateInputEl, helpEl, minDays) {
    const today = new Date();
    today.setDate(today.getDate() + minDays);
    
    // Formatear a YYYY-MM-DD
    const yyyy = today.getFullYear();
    const mm = String(today.getMonth() + 1).padStart(2, '0');
    const dd = String(today.getDate()).padStart(2, '0');
    const minDateStr = `${yyyy}-${mm}-${dd}`;
    
    dateInputEl.setAttribute('min', minDateStr);
    dateInputEl.value = minDateStr;
    
    if (helpEl) {
      helpEl.textContent = `Se requiere un mínimo de ${minDays} ${minDays === 1 ? 'día' : 'días'} de anticipación para este pedido (Disponible desde: ${dd}/${mm}/${yyyy}).`;
    }
  }

  // --- LOGICA DE EVENTOS DE BOTONES "PEDIR/PERSONALIZAR" ---
  const actionButtons = document.querySelectorAll('.btn-order-action');
  
  actionButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const productId = btn.getAttribute('data-id');
      const product = products.find(p => p.id === productId);
      if (!product) return;

      selectedProduct = product;

      if (product.tipoPrecio === 'dinamico') {
        initCotizador(product);
        openModal(modalCotizador);
      } else if (product.tipoPrecio === 'fijo') {
        initPedidoFijo(product);
        openModal(modalPedidoFijo);
      } else if (product.tipoPrecio === 'cotizar') {
        initQuote(product);
        openModal(modalQuote);
      }
    });
  });

  // Permitir abrir cotizador desde el botón del Hero
  document.getElementById('btn-hero-customize').addEventListener('click', (e) => {
    e.preventDefault();
    const customizedCake = products.find(p => p.id === 'torta-personalizada');
    if (customizedCake) {
      selectedProduct = customizedCake;
      initCotizador(customizedCake);
      openModal(modalCotizador);
    }
  });

  // --- INICIALIZADORES Y LOGICA DEL COTIZADOR DINAMICO ---
  function initCotizador(product) {
    document.getElementById('cotizador-title').textContent = product.nombre;
    quoteFillings = [];
    
    // Configurar fecha
    const dateInput = document.getElementById('date-delivery');
    const dateHelp = document.getElementById('date-help');
    setMinDate(dateInput, dateHelp, product.diasAnticipacion);

    // Renderizar Tamaños
    const containerSizes = document.getElementById('container-sizes');
    containerSizes.innerHTML = '';
    product.tamanos.forEach((size, idx) => {
      const isSelected = idx === 0;
      if (isSelected) quoteSize = size;

      const card = document.createElement('div');
      card.className = `option-card ${isSelected ? 'selected' : ''}`;
      card.innerHTML = `
        <span class="option-name">${size.nombre}</span>
        <span class="option-price">$${size.precio.toLocaleString('es-AR')}</span>
      `;
      
      card.addEventListener('click', () => {
        containerSizes.querySelectorAll('.option-card').forEach(c => c.classList.remove('selected'));
        card.classList.add('selected');
        quoteSize = size;
        updateCotizadorTotal();
      });

      containerSizes.appendChild(card);
    });

    // Renderizar Rellenos
    const containerFillings = document.getElementById('container-fillings');
    containerFillings.innerHTML = '';
    product.rellenos.forEach((filling) => {
      const row = document.createElement('div');
      row.className = 'option-row';
      row.innerHTML = `
        <div class="option-row-left">
          <input type="checkbox" class="option-checkbox" />
          <span class="option-name">${filling.nombre}</span>
        </div>
        <span class="option-price">${filling.precio > 0 ? `+$${filling.precio.toLocaleString('es-AR')}` : 'Sin costo adicional'}</span>
      `;

      row.addEventListener('click', (e) => {
        const checkbox = row.querySelector('.option-checkbox');
        // Si no clickeó directamente en el checkbox, lo toggleamos manualmente
        if (e.target !== checkbox) {
          checkbox.checked = !checkbox.checked;
        }
        
        if (checkbox.checked) {
          row.classList.add('selected');
          quoteFillings.push(filling);
        } else {
          row.classList.remove('selected');
          quoteFillings = quoteFillings.filter(f => f.nombre !== filling.nombre);
        }
        updateCotizadorTotal();
      });

      containerFillings.appendChild(row);
    });

    // Renderizar Diseños
    const containerDesigns = document.getElementById('container-designs');
    containerDesigns.innerHTML = '';
    product.disenos.forEach((design, idx) => {
      const isSelected = idx === 0;
      if (isSelected) quoteDesign = design;

      const card = document.createElement('div');
      card.className = `option-card ${isSelected ? 'selected' : ''}`;
      card.innerHTML = `
        <span class="option-name">${design.nombre}</span>
        <span class="option-price">${design.precio > 0 ? `+$${design.precio.toLocaleString('es-AR')}` : 'Sin costo adicional'}</span>
      `;

      card.addEventListener('click', () => {
        containerDesigns.querySelectorAll('.option-card').forEach(c => c.classList.remove('selected'));
        card.classList.add('selected');
        quoteDesign = design;
        updateCotizadorTotal();
      });

      containerDesigns.appendChild(card);
    });

    updateCotizadorTotal();
  }

  function updateCotizadorTotal() {
    let total = 0;
    if (quoteSize) total += quoteSize.precio;
    if (quoteDesign) total += quoteDesign.precio;
    quoteFillings.forEach(f => total += f.precio);

    document.getElementById('cotizador-total-price').textContent = `$${total.toLocaleString('es-AR')}`;
  }

  // --- INICIALIZADOR DE PEDIDO FIJO ---
  function initPedidoFijo(product) {
    document.getElementById('fijo-title').textContent = product.nombre;
    
    // Configurar fecha
    const dateInput = document.getElementById('fijo-date');
    const dateHelp = document.getElementById('fijo-date-help');
    setMinDate(dateInput, dateHelp, product.diasAnticipacion);

    const selectQty = document.getElementById('fijo-quantity');
    selectQty.value = "1";

    function updateFijoTotal() {
      const qty = parseInt(selectQty.value);
      const total = product.precio * qty;
      document.getElementById('fijo-total-price').textContent = `$${total.toLocaleString('es-AR')}`;
    }

    selectQty.onchange = updateFijoTotal;
    updateFijoTotal();
  }

  // --- INICIALIZADOR DE PEDIDO CONSULTA / BODA ---
  function initQuote(product) {
    const dateInput = document.getElementById('quote-date');
    const dateHelp = document.getElementById('quote-date-help');
    setMinDate(dateInput, dateHelp, product.diasAnticipacion);
  }

  // --- ENVIAR PEDIDOS A WHATSAPP ---

  // 1. Submit Cotizador Dinámico
  document.getElementById('btn-submit-cotizador').addEventListener('click', () => {
    const name = document.getElementById('customer-name').value.trim();
    const date = document.getElementById('date-delivery').value;
    const notes = document.getElementById('order-notes').value.trim();

    if (!name) {
      alert("Por favor ingresá tu nombre para que sepamos con quién hablar.");
      return;
    }
    if (!date) {
      alert("Por favor elegí una fecha de entrega.");
      return;
    }

    // Calcular total final
    let total = 0;
    if (quoteSize) total += quoteSize.precio;
    if (quoteDesign) total += quoteDesign.precio;
    quoteFillings.forEach(f => total += f.precio);

    // Formatear Fecha para el mensaje
    const dateParts = date.split('-');
    const formattedDate = `${dateParts[2]}/${dateParts[1]}/${dateParts[0]}`;

    // Construir mensaje
    let message = `¡Hola! Me gustaría cotizar un pedido para mi celebración:\n\n`;
    message += `🍰 *Producto:* ${selectedProduct.nombre}\n`;
    message += `📏 *Tamaño:* ${quoteSize.nombre}\n`;
    
    if (quoteFillings.length > 0) {
      message += `🍯 *Relleno(s) Especial(es):*\n`;
      quoteFillings.forEach(f => {
        message += `  - ${f.nombre}\n`;
      });
    } else {
      message += `🍯 *Rellenos:* Estándar a convenir\n`;
    }
    
    message += `🎨 *Estilo de Diseño:* ${quoteDesign.nombre}\n`;
    message += `📅 *Fecha solicitada:* ${formattedDate}\n`;
    if (notes) message += `📝 *Aclaraciones:* "${notes}"\n`;
    message += `👤 *Mi Nombre:* ${name}\n\n`;
    message += `💰 *Presupuesto Estimado:* $${total.toLocaleString('es-AR')} ARS\n\n`;
    message += `¿Tienen disponibilidad para esta fecha? ¡Muchas gracias!`;

    sendWhatsapp(message);
    closeModal(modalCotizador);
  });

  // 2. Submit Pedido Fijo
  document.getElementById('btn-submit-pedido-fijo').addEventListener('click', () => {
    const name = document.getElementById('fijo-customer-name').value.trim();
    const date = document.getElementById('fijo-date').value;
    const qty = parseInt(document.getElementById('fijo-quantity').value);
    const notes = document.getElementById('fijo-notes').value.trim();

    if (!name) {
      alert("Por favor ingresá tu nombre.");
      return;
    }
    if (!date) {
      alert("Por favor elegí la fecha.");
      return;
    }

    const total = selectedProduct.precio * qty;
    const dateParts = date.split('-');
    const formattedDate = `${dateParts[2]}/${dateParts[1]}/${dateParts[0]}`;

    let message = `¡Hola! Me gustaría hacer un pedido fijo:\n\n`;
    message += `🥧 *Producto:* ${selectedProduct.nombre}\n`;
    message += `🛍️ *Cantidad:* ${qty} ${qty === 1 ? 'unidad' : 'unidades'}\n`;
    message += `📅 *Fecha de Retiro:* ${formattedDate}\n`;
    if (notes) message += `📝 *Notas:* "${notes}"\n`;
    message += `👤 *Mi Nombre:* ${name}\n\n`;
    message += `💰 *Total a Abonar:* $${total.toLocaleString('es-AR')} ARS\n\n`;
    message += `¿Me confirman la reserva del pedido? ¡Muchas gracias!`;

    sendWhatsapp(message);
    closeModal(modalPedidoFijo);
  });

  // 3. Submit Pedido Bajo Cotización (Bodas/Eventos)
  document.getElementById('btn-submit-quote').addEventListener('click', () => {
    const name = document.getElementById('quote-customer-name').value.trim();
    const date = document.getElementById('quote-date').value;
    const guests = document.getElementById('quote-guests').value.trim();
    const details = document.getElementById('quote-details').value.trim();

    if (!name) {
      alert("Por favor ingresá tu nombre.");
      return;
    }
    if (!date) {
      alert("Por favor elegí la fecha del evento.");
      return;
    }
    if (!details) {
      alert("Por favor detallanos un poco qué tenés en mente.");
      return;
    }

    const dateParts = date.split('-');
    const formattedDate = `${dateParts[2]}/${dateParts[1]}/${dateParts[0]}`;

    let message = `¡Hola! Me comunico para cotizar un Pedido Especial o de Boda:\n\n`;
    message += `✨ *Tipo de Evento/Pedido:* ${selectedProduct.nombre}\n`;
    message += `👥 *Invitados aproximados:* ${guests}\n`;
    message += `📅 *Fecha del Evento:* ${formattedDate}\n`;
    message += `📝 *Detalles de lo que tengo en mente:*\n"${details}"\n\n`;
    message += `👤 *Mi Nombre:* ${name}\n\n`;
    message += `Espero su asesoramiento para armar la mesa dulce de mis sueños. ¡Gracias!`;

    sendWhatsapp(message);
    closeModal(modalQuote);
  });

  // Abre la URL de WhatsApp
  function sendWhatsapp(text) {
    const encodedText = encodeURIComponent(text);
    const url = `https://wa.me/${WHATSAPP_PHONE}?text=${encodedText}`;
    window.open(url, '_blank');
  }
</script>
